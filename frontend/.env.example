# Backend URL used by Next.js rewrites.
NEXT_PUBLIC_API_URL=http://localhost:8020

# development | production
NEXT_PUBLIC_OPENAPI_MODE=development

# Frontend fallback values. The backend /api/config/runtime response is preferred at runtime.
NEXT_PUBLIC_OPENAPI_DEV_KB_B2C_BASE_URL=https://ddeveloper.kbsec.com:32484
NEXT_PUBLIC_OPENAPI_DEV_KB_B2C_TOKEN_BASE_URL=https://ddeveloper.kbsec.com:32484
NEXT_PUBLIC_OPENAPI_PROD_KB_B2C_BASE_URL=https://developer.kbsec.com
NEXT_PUBLIC_OPENAPI_PROD_KB_B2C_TOKEN_BASE_URL=https://developer.kbsec.com
